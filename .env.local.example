# Melhor Envio - Credenciais da Aplicação OAuth
MELHOR_ENVIO_CLIENT_ID=25510
MELHOR_ENVIO_CLIENT_SECRET=seu_secret_aqui

# Melhor Envio - Tokens (gerados via /api/shipping/auth)
MELHOR_ENVIO_TOKEN=seu_access_token_aqui
MELHOR_ENVIO_REFRESH_TOKEN=seu_refresh_token_aqui

# CEP de origem (onde os produtos saem)
MELHOR_ENVIO_CEP_ORIGEM=38190000

# URL do site (usada no callback OAuth)
NEXT_PUBLIC_SITE_URL=https://seu-dominio.vercel.app
